# Frontend environment variables (local development defaults)
# Primary backend (Django API)
REACT_APP_DJANGO_API_URL=https://sneakr-lab-emvv.onrender.com

# Backward-compatible alias consumed by some API helpers
REACT_APP_API_URL=https://sneakr-lab-emvv.onrender.com

# Optional legacy Node API (if still used)
REACT_APP_NODE_API_URL=http://localhost:3001

# PayPal JS SDK client id
REACT_APP_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# Optional: external host for large 3D model assets (no trailing slash)
# Example: https://cdn.your-domain.com
REACT_APP_MODEL_ASSET_BASE_URL=

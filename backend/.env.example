# Django core
SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-backend.onrender.com

# Frontend URL (used by some endpoints/CORS)
FRONTEND_URL=https://your-frontend.vercel.app

# Preferred DB config for Render/Neon
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Optional explicit DB_* fallback (used if DATABASE_URL is not set)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=require

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# Vertex AI auth mode 1 (recommended): service account path on server
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/service-account.json

# Vertex AI auth mode 2: API key
# VERTEX_API_KEY=your_vertex_or_google_api_key_here
# VERTEX_PROJECT_ID=your_gcp_project_id_here
